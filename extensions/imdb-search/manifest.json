{
  "manifest_version": 3,
  "name": "IMDB Search",
  "version": "1.0.0",
  "description": "右键选中中文文字，在 IMDB 搜索电影（通过 TMDB API 翻译）",
  "permissions": ["contextMenus", "storage"],
  "host_permissions": ["https://api.themoviedb.org/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}