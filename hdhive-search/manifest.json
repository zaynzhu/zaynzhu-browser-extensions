{
  "manifest_version": 3,
  "name": "HDHive Search",
  "version": "1.0.0",
  "description": "右键选中文字，在 HDHive 中搜索影视资料",
  "permissions": ["contextMenus"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}